# Copy to terraform.tfvars and fill in. Do not commit terraform.tfvars.

# ── OCI ────────────────────────────────────────────────────────────────────────

tenancy_ocid     = "ocid1.tenancy.oc1..aaaa..."
user_ocid        = "ocid1.user.oc1..aaaa..."
fingerprint      = "aa:bb:cc:dd:ee:ff:00:11:22:33:44:55:66:77:88:99"
private_key_path = "~/.oci/oci_api_key.pem"
# CI: TF_VAR_private_key overrides private_key_path when set.

# deployment_id = "12345"

region = "eu-frankfurt-1"

# Often same as tenancy_ocid; avoid ManagedCompartmentForPaaS for this stack.
compartment_id = "ocid1.tenancy.oc1..aaaa..."

# ── Instance ─────────────────────────────────────────────────────────────────

availability_domain_number = 1
# availability_domain = "acDH:EU-FRANKFURT-1-AD-3"

instance_shape = "VM.Standard.A1.Flex"
# instance_shape = "VM.Standard.E2.1.Micro"
instance_hostname = "proxy"

# instance_flex_ocpus     = 1
# instance_flex_memory_gb = 6
# host_os = "debian-12"
# host_image_ocid = "ocid1.image.oc1..."

# ── Networking ────────────────────────────────────────────────────────────────

vcn_cidr    = "10.0.0.0/16"
subnet_cidr = "10.0.1.0/24"
# enable_ipv6 = true

# ── Access Control ────────────────────────────────────────────────────────────

home_ips = [
  "1.2.3.4",
  "5.6.7.8",
]

ssh_port   = 2222
panel_port = 54321
vless_port = 443

# panel_username = "myadmin"
# panel_password = "my-secret-password"

ssh_public_key = "ssh-ed25519 AAAAC3Nza... your-key-here"

admin_username = "sysadmin"
