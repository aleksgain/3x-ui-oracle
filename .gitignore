# =============================================================================
#  .gitignore — Oracle VPS Terraform
# =============================================================================

# ── Secrets — NEVER commit these ─────────────────────────────────────────────
terraform.tfvars
*.auto.tfvars
*.pem
*.key
*.p12

# ── Terraform state — contains resource IDs and may contain sensitive data ───
*.tfstate
*.tfstate.*
*.tfstate.backup

# ── Terraform working directory ───────────────────────────────────────────────
.terraform/

# Commit .terraform.lock.hcl for reproducible init in CI and on teammate machines.

# ── Crash logs ────────────────────────────────────────────────────────────────
crash.log
crash.*.log

# ── Override files ────────────────────────────────────────────────────────────
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# ── CLI config ────────────────────────────────────────────────────────────────
.terraformrc
terraform.rc
